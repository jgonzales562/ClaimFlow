# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://claimflowdev:Moonbeem7!@localhost:55432/claimflow?schema=public"

# Session signing secret for auth cookies (32+ chars recommended)
SESSION_SECRET="change-this-to-a-long-random-secret-value"

# Postmark inbound webhook auth (recommended by Postmark docs)
POSTMARK_WEBHOOK_BASIC_AUTH_USER="postmark"
POSTMARK_WEBHOOK_BASIC_AUTH_PASS="change-this-password"

# Fallback org slug when mailbox hash cannot be resolved
POSTMARK_DEFAULT_ORG_SLUG="acme-warranty"
