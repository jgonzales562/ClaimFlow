# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://claimflowdev:Moonbeem7!@localhost:55432/claimflow?schema=public"

# Session signing secret for auth cookies (32+ chars recommended)
SESSION_SECRET="change-this-to-a-long-random-secret-value"

# Postmark inbound webhook auth (recommended by Postmark docs)
POSTMARK_WEBHOOK_BASIC_AUTH_USER="postmark"
POSTMARK_WEBHOOK_BASIC_AUTH_PASS="change-this-password"
POSTMARK_ATTACHMENT_PERSIST_CONCURRENCY="3"

# Fallback org slug when mailbox hash cannot be resolved
POSTMARK_DEFAULT_ORG_SLUG="acme-warranty"

# AWS/S3 attachment storage
AWS_REGION="us-east-1"
ATTACHMENTS_S3_BUCKET="claimflow-attachments-dev"
ATTACHMENTS_S3_PREFIX="claimflow"
ATTACHMENTS_SIGNED_URL_TTL_SECONDS="300"

# AWS/SQS claim ingest queue settings
CLAIMS_INGEST_QUEUE_URL=""
CLAIMS_INGEST_DLQ_URL=""
CLAIMS_QUEUE_MAX_RECEIVE_COUNT="5"
CLAIMS_QUEUE_POLL_WAIT_SECONDS="20"
CLAIMS_QUEUE_MAX_MESSAGES="5"
CLAIMS_WORKER_CONCURRENCY="1"
CLAIMS_QUEUE_VISIBILITY_TIMEOUT_SECONDS=""
CLAIMS_QUEUE_IDLE_DELAY_MS="250"
CLAIMS_QUEUE_ERROR_DELAY_MS="2000"

# OpenAI extraction settings
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
CLAIMS_EXTRACTION_READY_CONFIDENCE="0.85"
CLAIMS_EXTRACTION_MAX_INPUT_CHARS="12000"

# Textract fallback settings
CLAIMS_TEXTRACT_FALLBACK_ENABLED="true"
CLAIMS_TEXTRACT_FALLBACK_CONFIDENCE_THRESHOLD="0.75"
CLAIMS_TEXTRACT_FALLBACK_MISSING_INFO_COUNT="3"
CLAIMS_TEXTRACT_FALLBACK_MIN_INBOUND_CHARS="120"
CLAIMS_TEXTRACT_MAX_ATTACHMENTS="5"
CLAIMS_TEXTRACT_MAX_TEXT_CHARS="30000"

# Sentry observability settings (web + worker)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
