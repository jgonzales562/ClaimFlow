generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum ClaimStatus {
  NEW
  PROCESSING
  REVIEW_REQUIRED
  READY
  ERROR
}

enum WarrantyStatus {
  LIKELY_IN_WARRANTY
  LIKELY_EXPIRED
  UNCLEAR
}

enum InboundEmailProvider {
  POSTMARK
}

enum AttachmentStorageProvider {
  S3
}

enum AttachmentUploadStatus {
  STORED
  FAILED
}

enum ClaimExtractionProvider {
  OPENAI
  FALLBACK
}

enum ClaimEventType {
  MANUAL_EDIT
  STATUS_TRANSITION
}

model Organization {
  id                     String                   @id @default(cuid())
  name                   String
  slug                   String                   @unique
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  memberships            Membership[]
  claims                 Claim[]
  claimOrganizationSummary ClaimOrganizationSummary?
  integrationMailbox     IntegrationMailbox[]
  inboundMessages        InboundMessage[]
  claimAttachments       ClaimAttachment[]
  claimExtractions       ClaimExtraction[]
  claimEvents            ClaimEvent[]
  claimIngestQueueOutbox ClaimIngestQueueOutbox[]
}

model ClaimOrganizationSummary {
  organizationId        String       @id
  totalClaims           Int          @default(0)
  newCount              Int          @default(0)
  processingCount       Int          @default(0)
  reviewRequiredCount   Int          @default(0)
  readyCount            Int          @default(0)
  errorCount            Int          @default(0)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  fullName      String?
  passwordHash  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]
  createdClaims Claim[]      @relation("ClaimCreatedBy")
  claimEvents   ClaimEvent[] @relation("ClaimEventActor")
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(ANALYST)
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Claim {
  id                              String                   @id @default(cuid())
  organizationId                  String
  externalClaimId                 String?
  sourceEmail                     String?
  customerName                    String?
  productName                     String?
  serialNumber                    String?
  purchaseDate                    DateTime?
  issueSummary                    String?
  retailer                        String?
  warrantyStatus                  WarrantyStatus           @default(UNCLEAR)
  missingInfo                     String[]                 @default([])
  status                          ClaimStatus              @default(NEW)
  processingAttempt               Int                      @default(0)
  processingLeaseToken            String?
  processingLeaseClaimedAt        DateTime?
  latestWorkerFailureAt           DateTime?
  latestWorkerFailureReason       String?
  latestWorkerFailureRetryable    Boolean?
  latestWorkerFailureReceiveCount Int?
  latestWorkerFailureDisposition  String?
  createdByUserId                 String?
  createdAt                       DateTime                 @default(now())
  updatedAt                       DateTime                 @updatedAt
  organization                    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser                   User?                    @relation("ClaimCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  inboundMessages                 InboundMessage[]
  attachments                     ClaimAttachment[]
  extractions                     ClaimExtraction[]
  events                          ClaimEvent[]
  ingestQueueOutbox               ClaimIngestQueueOutbox[]

  @@unique([organizationId, externalClaimId])
  @@index([organizationId, status, createdAt, id], map: "Claim_organizationId_status_createdAt_id_idx")
  @@index([organizationId, status, updatedAt, id], map: "Claim_organizationId_status_updatedAt_id_idx")
  @@index([organizationId, status, latestWorkerFailureAt, id], map: "Claim_error_failure_at_idx")
  @@index([organizationId, status, latestWorkerFailureReceiveCount, updatedAt, id], map: "Claim_error_failure_count_idx")
  @@index([organizationId, status, latestWorkerFailureRetryable, updatedAt, id], map: "Claim_error_retryable_idx")
  @@index([organizationId, status, latestWorkerFailureDisposition, updatedAt, id], map: "Claim_error_disposition_idx")
  @@index([organizationId, createdAt, id], map: "Claim_organizationId_createdAt_id_idx")
  @@index([status, updatedAt, id], map: "Claim_status_updatedAt_id_idx")
}

model ClaimIngestQueueOutbox {
  id                     String       @id
  organizationId         String
  claimId                String
  inboundMessageId       String
  providerMessageId      String
  queueUrl               String
  processingAttempt      Int
  processingLeaseToken   String
  availableAt            DateTime
  dispatchAttempts       Int          @default(0)
  lastDispatchAttemptAt  DateTime?
  lastDispatchError      String?
  dispatchedAt           DateTime?
  sqsMessageId           String?
  dispatchLeaseToken     String?
  dispatchLeaseClaimedAt DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claim                  Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, createdAt], map: "ClaimIngestQueueOutbox_claimId_createdAt_idx")
  @@index([dispatchedAt, availableAt, createdAt, id], map: "ClaimIngestQueueOutbox_dispatch_state_idx")
  @@index([organizationId, dispatchedAt, createdAt, id], map: "ClaimIngestQueueOutbox_org_dispatch_created_id_idx")
  @@index([organizationId, dispatchedAt, availableAt, id], map: "ClaimIngestQueueOutbox_org_dispatch_available_id_idx")
}

model IntegrationMailbox {
  id             String               @id @default(cuid())
  organizationId String
  provider       InboundEmailProvider @default(POSTMARK)
  mailboxHash    String
  emailAddress   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([provider, mailboxHash])
  @@index([organizationId])
}

model InboundMessage {
  id                String               @id @default(cuid())
  organizationId    String
  provider          InboundEmailProvider @default(POSTMARK)
  providerMessageId String
  mailboxHash       String?
  fromEmail         String?
  fromName          String?
  toEmail           String?
  subject           String?
  receivedAt        DateTime?
  textBody          String?
  htmlBody          String?
  strippedTextReply String?
  rawPayload        Json
  claimId           String?
  createdAt         DateTime             @default(now())
  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claim             Claim?               @relation(fields: [claimId], references: [id], onDelete: SetNull)
  attachments       ClaimAttachment[]
  extractions       ClaimExtraction[]

  @@unique([organizationId, provider, providerMessageId])
  @@index([organizationId, createdAt])
  @@index([claimId, createdAt], map: "InboundMessage_claimId_createdAt_idx")
}

model ClaimAttachment {
  id               String                    @id @default(cuid())
  organizationId   String
  claimId          String
  inboundMessageId String?
  storageProvider  AttachmentStorageProvider @default(S3)
  uploadStatus     AttachmentUploadStatus    @default(STORED)
  originalFilename String
  contentType      String?
  byteSize         Int
  checksumSha256   String?
  s3Bucket         String
  s3Key            String
  errorMessage     String?
  createdAt        DateTime                  @default(now())
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claim            Claim                     @relation(fields: [claimId], references: [id], onDelete: Cascade)
  inboundMessage   InboundMessage?           @relation(fields: [inboundMessageId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([claimId, createdAt, id], map: "ClaimAttachment_claimId_createdAt_id_idx")
  @@index([claimId, uploadStatus, createdAt, id], map: "ClaimAttachment_claimId_uploadStatus_createdAt_id_idx")
  @@index([inboundMessageId])
}

model ClaimExtraction {
  id               String                  @id @default(cuid())
  organizationId   String
  claimId          String
  inboundMessageId String?
  provider         ClaimExtractionProvider @default(OPENAI)
  model            String
  schemaVersion    Int                     @default(1)
  confidence       Float
  extraction       Json
  rawOutput        Json
  createdAt        DateTime                @default(now())
  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claim            Claim                   @relation(fields: [claimId], references: [id], onDelete: Cascade)
  inboundMessage   InboundMessage?         @relation(fields: [inboundMessageId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([claimId, createdAt, id], map: "ClaimExtraction_claimId_createdAt_id_idx")
  @@index([inboundMessageId])
}

model ClaimEvent {
  id             String         @id @default(cuid())
  organizationId String
  claimId        String
  actorUserId    String?
  eventType      ClaimEventType
  payload        Json
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claim          Claim          @relation(fields: [claimId], references: [id], onDelete: Cascade)
  actorUser      User?          @relation("ClaimEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([claimId, createdAt, id], map: "ClaimEvent_claimId_createdAt_id_idx")
  @@index([claimId, eventType, createdAt, id], map: "ClaimEvent_claimId_eventType_createdAt_id_idx")
  @@index([organizationId, eventType, createdAt], map: "ClaimEvent_organizationId_eventType_createdAt_idx")
  @@index([eventType, createdAt], map: "ClaimEvent_eventType_createdAt_idx")
  @@index([actorUserId, createdAt])
}
