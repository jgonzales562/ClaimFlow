{
  "name": "@claimflow/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "predev": "node ../../scripts/ensure-db-build.mjs",
    "prebuild": "node ../../scripts/ensure-db-build.mjs",
    "dev": "node ../../scripts/run-with-root-env.mjs next dev",
    "build": "node ../../scripts/run-with-root-env.mjs next build",
    "start": "node ../../scripts/run-with-root-env.mjs next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit --incremental false"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.876.0",
    "@aws-sdk/client-sqs": "^3.876.0",
    "@aws-sdk/s3-request-presigner": "^3.876.0",
    "@claimflow/db": "workspace:*",
    "@prisma/client": "^6.4.1",
    "@sentry/nextjs": "^10.22.0",
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10"
  }
